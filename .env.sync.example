# Supabase Database Sync Configuration
# Copy this file to .env.sync and fill in your actual credentials
# DO NOT commit .env.sync to git - it contains sensitive information

# Supabase Service Role Key (required for admin access to dump all data)
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Database Connection URL
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Get this from: Supabase Dashboard > Settings > Database > Connection string > URI
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Project Reference (used for validation)
# Get this from your Supabase project URL: https://[project-ref].supabase.co
SUPABASE_PROJECT_REF=your-project-ref

# Local PostgreSQL Connection (usually don't need to change these)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=retroscope
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres
