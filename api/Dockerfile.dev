FROM mcr.microsoft.com/dotnet/sdk:9.0

WORKDIR /src

# Copy solution and project files
COPY *.sln ./
COPY global.json ./
COPY src/Retroscope.Api/*.csproj ./src/Retroscope.Api/
COPY src/Retroscope.Application/*.csproj ./src/Retroscope.Application/
COPY src/Retroscope.Auth/*.csproj ./src/Retroscope.Auth/
COPY src/Retroscope.Infrastructure/*.csproj ./src/Retroscope.Infrastructure/
COPY tests/Retroscope.Api.UnitTests/*.csproj ./tests/Retroscope.Api.UnitTests/
COPY tests/Retroscope.Api.IntegrationTests/*.csproj ./tests/Retroscope.Api.IntegrationTests/

# Restore dependencies
RUN dotnet restore src/Retroscope.Api/Retroscope.Api.csproj

# Copy everything else
COPY . .

# Expose API port
EXPOSE 8080

# Run with hot reload
CMD ["dotnet", "watch", "run", "--project", "src/Retroscope.Api/Retroscope.Api.csproj", "--no-restore", "--no-launch-profile"]

